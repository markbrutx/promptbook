{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignoreExportsUsedInFile": true,
  "workspaces": {
    ".": {
      "entry": ["test-support/**/*.ts"],
      "project": "test-support/**/*.ts"
    },
    "packages/core": {
      "entry": ["src/index.ts", "src/edge.ts", "test/**/*.test.ts"],
      "project": ["src/**/*.ts", "scripts/**/*.mjs"]
    },
    "packages/cli": {
      "entry": ["src/index.ts", "bin/promptbook.ts", "test/**/*.test.ts"],
      "project": "src/**/*.ts"
    },
    "packages/openrouter": {
      "entry": ["src/index.ts", "test/**/*.test.ts"],
      "project": "src/**/*.ts"
    },
    "packages/viewer": {
      "entry": ["src/index.ts", "test/**/*.test.ts"],
      "project": ["src/**/*.ts", "src/**/*.tsx"],
      "ignore": ["src/web/env.d.ts"]
    },
    "apps/site": {
      "entry": [
        "app/**/{page,layout,template,error,loading,not-found,route,default,sitemap,robots,opengraph-image,twitter-image,icon,apple-icon}.{ts,tsx}"
      ],
      "project": [
        "src/**/*.{ts,tsx}",
        "app/**/*.{ts,tsx}"
      ],
      "ignoreDependencies": [
        "@types/mdx"
      ]
    }
  }
}
