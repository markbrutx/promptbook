{
  "name": "promptbook-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=20.6"
  },
  "scripts": {
    "build": "npm -ws --if-present run build",
    "typecheck": "npm -ws --if-present run typecheck",
    "test": "npm -ws --if-present run test",
    "check": "npm -ws --if-present run check && npm run deadcode",
    "deadcode": "knip"
  },
  "devDependencies": {
    "knip": "^6.14.2"
  }
}
