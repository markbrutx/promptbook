{
  "name": "@markbrutx/promptbook-viewer",
  "version": "0.3.0",
  "description": "Storybook-for-prompts: a local web app that renders a prompts folder via @markbrutx/promptbook-core.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "prompt",
    "prompt-engineering",
    "prompt-management",
    "llm",
    "ai",
    "viewer",
    "storybook",
    "composition"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/markbrutx/promptbook.git",
    "directory": "packages/viewer"
  },
  "homepage": "https://github.com/markbrutx/promptbook#readme",
  "bugs": "https://github.com/markbrutx/promptbook/issues",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./web": {
      "types": "./src/web/mount.tsx",
      "default": "./src/web/mount.tsx"
    },
    "./web/styles.css": "./src/web/styles.css"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsgo -p tsconfig.build.json && vite build",
    "typecheck": "tsgo --noEmit -p tsconfig.json && tsgo --noEmit -p tsconfig.web.json",
    "test": "vitest --run",
    "check": "biome check ."
  },
  "dependencies": {
    "@markbrutx/promptbook-core": "^0.3.0"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@types/node": "^20.14.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@typescript/native-preview": "latest",
    "@vitejs/plugin-react": "^4.7.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.6"
  }
}
