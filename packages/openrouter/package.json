{
  "name": "@markbrutx/promptbook-openrouter",
  "version": "0.4.3",
  "description": "OpenRouter ModelAdapter for @markbrutx/promptbook-core eval. Network lives here; core stays pure.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "prompt",
    "prompt-engineering",
    "llm",
    "ai",
    "openrouter",
    "eval",
    "model-adapter"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/markbrutx/promptbook.git",
    "directory": "packages/openrouter"
  },
  "homepage": "https://github.com/markbrutx/promptbook#readme",
  "bugs": "https://github.com/markbrutx/promptbook/issues",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsgo -p tsconfig.build.json",
    "typecheck": "tsgo --noEmit -p tsconfig.json",
    "test": "vitest --run",
    "check": "biome check ."
  },
  "dependencies": {
    "@markbrutx/promptbook-core": "^0.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@types/node": "^20.14.0",
    "@typescript/native-preview": "latest",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.6"
  }
}
