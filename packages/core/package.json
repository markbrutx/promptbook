{
  "name": "@markbrutx/promptbook-core",
  "version": "0.4.1",
  "description": "Agnostic, deterministic core for composing prompts from reusable fragments via declarative rules.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "prompt",
    "prompt-engineering",
    "prompt-management",
    "llm",
    "ai",
    "composition",
    "deterministic",
    "agnostic"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/markbrutx/promptbook.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/markbrutx/promptbook#readme",
  "bugs": "https://github.com/markbrutx/promptbook/issues",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./edge": {
      "types": "./dist/edge.d.ts",
      "import": "./dist/edge/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsgo -p tsconfig.build.json && npm run build:edge",
    "build:edge": "node scripts/build-edge.mjs",
    "typecheck": "tsgo --noEmit -p tsconfig.json",
    "test": "vitest --run",
    "check": "biome check ."
  },
  "dependencies": {
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@types/node": "^20.14.0",
    "@typescript/native-preview": "latest",
    "esbuild": "^0.21.5",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.6"
  }
}
