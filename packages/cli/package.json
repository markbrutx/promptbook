{
  "name": "@markbrutx/promptbook-cli",
  "version": "0.4.1",
  "description": "Thin terminal surface over @markbrutx/promptbook-core: resolve and ls for agents and CI.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "prompt",
    "prompt-engineering",
    "prompt-management",
    "llm",
    "ai",
    "cli",
    "composition",
    "storybook"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/markbrutx/promptbook.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/markbrutx/promptbook#readme",
  "bugs": "https://github.com/markbrutx/promptbook/issues",
  "bin": {
    "promptbook": "dist/bin/promptbook.js"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "src",
    "bin"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsgo -p tsconfig.build.json",
    "typecheck": "tsgo --noEmit -p tsconfig.json",
    "test": "vitest --run",
    "check": "biome check ."
  },
  "dependencies": {
    "@markbrutx/promptbook-core": "^0.4.1",
    "@markbrutx/promptbook-openrouter": "^0.4.1",
    "chokidar": "^4.0.3"
  },
  "optionalDependencies": {
    "@markbrutx/promptbook-viewer": "^0.4.1"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@types/node": "^20.14.0",
    "@typescript/native-preview": "latest",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.6"
  }
}
