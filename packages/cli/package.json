{
  "name": "@promptbook/cli",
  "version": "0.0.0",
  "description": "Thin terminal surface over @promptbook/core: resolve and ls for agents and CI.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "promptbook": "./dist/bin/promptbook.js"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist",
    "src",
    "bin"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsgo -p tsconfig.build.json",
    "typecheck": "tsgo --noEmit -p tsconfig.json",
    "test": "vitest --run",
    "check": "biome check ."
  },
  "dependencies": {
    "@promptbook/core": "*",
    "@promptbook/openrouter": "*"
  },
  "optionalDependencies": {
    "@promptbook/viewer": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@types/node": "^20.14.0",
    "@typescript/native-preview": "latest",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.6"
  }
}
